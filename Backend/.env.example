PORT=3000
NODE_ENV=development

# Preferred single URL for hosted PostgreSQL. Leave empty when using DB_* variables.
# DATABASE_URL=postgres://postgres:CHANGE_ME@localhost:5432/pg_kids_db

DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=pg_kids_db
DB_USER=postgres
DB_PASSWORD=CHANGE_ME
DB_LOGGING=false

# Local development only. Keep false for production/stable demos and use migrations later.
DB_SYNC_ALTER=true

# Required for production. Use a long random value.
AUTH_TOKEN_SECRET=CHANGE_ME_LONG_RANDOM_SECRET
AUTH_TOKEN_TTL_HOURS=12

# Used only to create initial admin/content_manager accounts through /api/auth/register.
ADMIN_SETUP_TOKEN=CHANGE_ME_SETUP_TOKEN

# Comma-separated allowed origins. Empty allows local dev origins when NODE_ENV is not production.
# CORS_ORIGINS=http://localhost:3000,http://192.168.1.10:3000
CORS_ORIGINS=

# Local storage fallback. Replace with S3/Azure Blob when confirmed by the company.
UPLOAD_DIR=uploads
MAX_MEDIA_FILE_SIZE_MB=50
